# App Config
PORT=4000
NODE_ENV=development
JWT_SECRET=super-secret-key-change-in-prod

# Database Config (matches docker-compose)
DATABASE_URL="postgresql://drofit_user:drofit_password@localhost:5432/drofit_metrics_db?schema=public"

# Redis Config
REDIS_URL="redis://localhost:6379"

# Integrations
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_..."
SHOPIFY_WEBHOOK_SECRET="whsec_..."

META_APP_ID="..."
META_APP_SECRET="..."
META_ACCESS_TOKEN="EAA..."
META_AD_ACCOUNT_ID="act_..."

GOOGLE_ADS_CLIENT_ID="..."
GOOGLE_ADS_CLIENT_SECRET="..."
GOOGLE_ADS_REFRESH_TOKEN="..."
GOOGLE_ADS_DEVELOPER_TOKEN="..."
GOOGLE_ADS_MANAGER_ID="..."
GOOGLE_ADS_CUSTOMER_ID="..."

DROPI_WEBHOOK_SECRET="change-this-to-a-strong-secret"

# Payments - MercadoPago
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."

# Payments - PayPal
# 1. Create sandbox app at https://developer.paypal.com/dashboard/applications/sandbox
# 2. Set CLIENT_ID and CLIENT_SECRET below
# 3. Run: npx tsx src/scripts/setup-paypal-plans.ts (creates Products + Billing Plans)
# 4. Copy the plan IDs printed by the script into PAYPAL_PLAN_PRO_ID and PAYPAL_PLAN_SCALE_ID
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."
PAYPAL_API_URL="https://api-m.sandbox.paypal.com"
PAYPAL_PLAN_PRO_ID="..."
PAYPAL_PLAN_SCALE_ID="..."

# URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
