generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id           String         @id @default(uuid())
  name         String
  logoUrl      String?        @map("logo_url")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  status       String         @default("ACTIVE")
  adSpends     AdSpend[]
  dailyMetrics DailyMetric[]
  fixedCosts   FixedCost[]
  settings     GlobalSetting?
  integrations Integration[]
  orders       Order[]
  products     Product[]
  shipments    Shipment[]
  users        User[]
  auditLogs    AuditLog[]

  @@map("workspaces")
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  passwordHash       String
  name               String?
  phone              String?
  role               String          @default("USER")
  workspaceId        String?         @map("workspace_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  mustChangePassword Boolean         @default(false) @map("must_change_password")
  workspace          Workspace?      @relation(fields: [workspaceId], references: [id])
  preferences        UserPreference?

  @@map("users")
}

model UserPreference {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  theme            String  @default("system")
  compactMode      Boolean @default(false) @map("compact_mode")
  emailReports     Boolean @default(true) @map("email_reports")
  alertMarginLow   Boolean @default(true) @map("alert_margin_low")
  alertStockout    Boolean @default(false) @map("alert_stockout")
  defaultDateRange String  @default("7d") @map("default_date_range")
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model GlobalSetting {
  id                String    @id @default(uuid())
  workspaceId       String    @unique @map("workspace_id")
  timezone          String    @default("santiago")
  currency          String    @default("usd")
  strictAttribution Boolean   @default(false) @map("strict_attribution")
  taxRate           Decimal   @default(0) @map("tax_rate") @db.Decimal(10, 2)
  gatewayPercent    Decimal   @default(0) @map("gateway_percent") @db.Decimal(10, 2)
  gatewayFixed      Decimal   @default(0) @map("gateway_fixed") @db.Decimal(10, 2)
  customFees        Json      @default("[]") @map("custom_fees")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("global_settings")
}

model Integration {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  platform    String
  name        String
  status      String    @default("Disconnected")
  type        String
  config      Json      @default("{}")
  lastSync    DateTime? @map("last_sync")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform])
  @@map("integrations")
}

model Order {
  id                String     @id @default(uuid())
  workspaceId       String     @map("workspace_id")
  orderId           String     @unique @map("order_id")
  shopifyId         String     @unique @map("shopify_id")
  customerName      String?    @map("customer_name")
  customerEmail     String?    @map("customer_email")
  totalPrice        Decimal    @map("total_price") @db.Decimal(10, 2)
  currency          String     @default("USD")
  financialStatus   String     @map("financial_status")
  fulfillmentStatus String?    @map("fulfillment_status")
  lineItems         Json       @map("line_items")
  createdAt         DateTime   @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  workspace         Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shipments         Shipment[]

  @@unique([workspaceId, shopifyId])
  @@unique([workspaceId, orderId])
  @@map("orders")
}

model AdSpend {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  platform        String
  campaignId      String    @map("campaign_id")
  campaignName    String    @map("campaign_name")
  spend           Decimal   @db.Decimal(10, 2)
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  conversions     Int       @default(0)
  conversionValue Decimal?  @map("conversion_value") @db.Decimal(10, 2)
  date            DateTime  @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform, campaignId, date])
  @@map("ad_spend")
}

model Shipment {
  id             String    @id @default(uuid())
  workspaceId    String    @map("workspace_id")
  guideId        String    @unique @map("guide_id")
  orderId        String?   @map("order_id")
  clientName     String    @map("client_name")
  city           String
  status         String
  collectedValue Decimal?  @map("collected_value") @db.Decimal(10, 2)
  shippingFee    Decimal?  @map("shipping_fee") @db.Decimal(10, 2)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  order          Order?    @relation(fields: [orderId], references: [orderId])
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, guideId])
  @@map("shipments")
}

model Product {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  sku         String    @unique
  name        String
  cogs        Decimal   @db.Decimal(10, 2)
  price       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sku])
  @@map("products")
}

model FixedCost {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  amount      Decimal   @db.Decimal(10, 2)
  category    String
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("fixed_costs")
}


model DailyMetric {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  date          DateTime  @db.Date
  totalRevenue  Decimal   @default(0) @map("total_revenue") @db.Decimal(10, 2)
  metaAdSpend   Decimal   @default(0) @map("meta_ad_spend") @db.Decimal(10, 2)
  googleAdSpend Decimal   @default(0) @map("google_ad_spend") @db.Decimal(10, 2)
  tiktokAdSpend Decimal   @default(0) @map("tiktok_ad_spend") @db.Decimal(10, 2)
  totalShipping Decimal   @default(0) @map("total_shipping") @db.Decimal(10, 2)
  totalCogs     Decimal   @default(0) @map("total_cogs") @db.Decimal(10, 2)
  netProfit     Decimal   @default(0) @map("net_profit") @db.Decimal(10, 2)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date])
  @@map("daily_metrics")
}

model AuditLog {
  id          String    @id @default(uuid())
  workspaceId String?   @map("workspace_id")
  source      String    // Shopify, Meta, Dropi, etc.
  event       String    // orders/create, sync, etc.
  status      String    // 200 OK, 500 Error, etc.
  message     String?   // Optional details
  payload     Json?     // Optional raw event data
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
